#!/command/with-contenv sh
# shellcheck shell=sh
# Railway all-in-one bootstrap: /opt/data volume, agent state in /opt/data/.hermes.

set -eu

DATA_DIR="${HERMES_DATA_DIR:-/opt/data}"
HERMES_HOME="${HERMES_HOME:-${DATA_DIR}/.hermes}"
WEBUI_STATE="${HERMES_WEBUI_STATE_DIR:-${DATA_DIR}/webui}"
WORKSPACE="${HERMES_WORKSPACE_DIR:-${DATA_DIR}/workspace}"

# Migrate legacy flat layout (config.yaml at volume root) into .hermes/.
if [ -f "${DATA_DIR}/config.yaml" ] && [ ! -f "${HERMES_HOME}/config.yaml" ]; then
    echo "[all-in-one] migrating flat volume layout to ${HERMES_HOME}"
    mkdir -p "${HERMES_HOME}"
    for base in $(ls -A "${DATA_DIR}"); do
        case "${base}" in
            webui|workspace|.hermes|.admin_signing_key) continue ;;
        esac
        mv "${DATA_DIR}/${base}" "${HERMES_HOME}/"
    done
fi

# Fresh volume mounts at /opt/data are often root:root; hermes must be able to
# create webui/, workspace/, and .hermes/ siblings. Chown the mount point only
# (not recursive) so host-owned files inside the volume keep their ownership.
mkdir -p "$DATA_DIR"
actual_hermes_uid=$(id -u hermes)
if [ "$(stat -c %u "$DATA_DIR" 2>/dev/null)" != "$actual_hermes_uid" ]; then
    echo "[all-in-one] Setting ownership of ${DATA_DIR} to hermes (${actual_hermes_uid})"
    chown hermes:hermes "$DATA_DIR" 2>/dev/null || \
        echo "[all-in-one] Warning: chown ${DATA_DIR} failed (rootless?) — continuing"
fi

mkdir -p "${DATA_DIR}/.tailscale"

s6-setuidgid hermes mkdir -p \
    "${HERMES_HOME}" \
    "${HERMES_HOME}/sessions" \
    "${HERMES_HOME}/skills" \
    "${HERMES_HOME}/optional-skills" \
    "${HERMES_HOME}/pairing" \
    "${WEBUI_STATE}" \
    "${WORKSPACE}"

for f in telegram-approved.json telegram-pending.json _rate_limits.json; do
    target="$HERMES_HOME/pairing/$f"
    if [ ! -s "$target" ]; then
        printf '{}' | s6-setuidgid hermes tee "$target" >/dev/null
    fi
done
chmod 600 "$HERMES_HOME"/pairing/*.json 2>/dev/null || true

if [ -d /opt/hermes/skills ]; then
    s6-setuidgid hermes cp -rn /opt/hermes/skills/. "$HERMES_HOME/skills/" 2>/dev/null || true
fi
if [ -d /opt/hermes/optional-skills ]; then
    s6-setuidgid hermes cp -rn /opt/hermes/optional-skills/. "$HERMES_HOME/optional-skills/" 2>/dev/null || true
fi

# Gateway autostart runs from control-plane on_startup (after s6-svscan is
# listening). cont-init is too early — hermes gateway start / s6-svc -u fails
# with "supervisor not listening" (rc=102).

echo "[all-in-one] bootstrap complete (HERMES_DATA_DIR=${DATA_DIR} HERMES_HOME=${HERMES_HOME})"
