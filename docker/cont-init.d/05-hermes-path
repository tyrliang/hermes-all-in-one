#!/command/with-contenv sh
# shellcheck shell=sh
# Ensure Node/npm and the hermes venv are on PATH for railway ssh / docker exec.
# The base image installs Node at /usr/local/bin; Railway SSH often inherits a
# minimal PATH (/usr/bin:/bin) that omits it, so `hermes --tui` fails with
# "node not found" even though the binary is present.

set -eu

PATH_PREFIX="/usr/local/bin:/opt/hermes/bin:/opt/hermes/.venv/bin:/opt/data/.local/bin"
current="${PATH:-/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin}"
new_path="${PATH_PREFIX}:${current}"

export PATH="${new_path}"

if [ -d /run/s6/container_environment ]; then
    printf '%s' "${new_path}" > /run/s6/container_environment/PATH
    printf '%s' "/usr/local/bin/node" > /run/s6/container_environment/HERMES_NODE
fi

mkdir -p /etc/profile.d
cat > /etc/profile.d/hermes-path.sh <<'EOF'
# Hermes all-in-one — Node and hermes CLI on PATH for ssh/exec shells
export PATH="/usr/local/bin:/opt/hermes/bin:/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH:-}"
export HERMES_NODE="${HERMES_NODE:-/usr/local/bin/node}"
EOF
chmod 644 /etc/profile.d/hermes-path.sh

if [ -d /etc/zsh ]; then
    mkdir -p /etc/zsh/zshenv.d
    cat > /etc/zsh/zshenv.d/50-hermes-path.zsh <<'EOF'
# Hermes all-in-one — Node on PATH (railway ssh uses zsh with a minimal PATH)
export PATH="/usr/local/bin:/opt/hermes/bin:/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH:-}"
export HERMES_NODE="${HERMES_NODE:-/usr/local/bin/node}"
EOF
fi

node_ver="?"
if [ -x /usr/local/bin/node ]; then
    node_ver="$(/usr/local/bin/node -v 2>/dev/null || echo '?')"
fi
echo "[all-in-one] PATH includes /usr/local/bin (Node ${node_ver})"
