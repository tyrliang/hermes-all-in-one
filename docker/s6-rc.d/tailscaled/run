#!/command/with-contenv sh
# shellcheck shell=sh
# Tailscale userspace networking (no TUN / NET_ADMIN) for Railway and similar hosts.
# Inbound: tailnet → Tailscale IP:$PORT forwards to localhost:$PORT (control plane).
# Outbound to other tailnet nodes: optional TAILSCALE_OUTBOUND_PROXY (see cont-init 04).
# Subnet routes from other nodes: optional TAILSCALE_ACCEPT_ROUTES (needs outbound proxy).
#
# SSH (TAILSCALE_SSH) — Railway uses userspace networking; Tailscale SSH (--ssh) often
# accepts TCP :22 but never sends an SSH banner (client hangs after "Local version string").
# Default openssh: real sshd on loopback + `tailscale serve --tcp 22`.
#   openssh (default) — stock `ssh user@host` + /opt/data/.ssh/authorized_keys
#   tailscale         — `tailscale up --ssh` (can hang on userspace; not recommended here)
#   0                 — off

# No auth key: hold the dependency slot open without joining a tailnet.
case "${TAILSCALE_AUTH_KEY:-}" in
    "") exec sleep infinity ;;
esac

DATA_DIR="${HERMES_DATA_DIR:-/opt/data}"
TS_STATE_DIR="${TAILSCALE_STATE_DIR:-${DATA_DIR}/.tailscale}"
TS_SOCKET="${TAILSCALE_SOCKET:-/run/tailscale/tailscaled.sock}"
TS_HOSTNAME="${TAILSCALE_HOSTNAME:-${RAILWAY_SERVICE_NAME:-hermes-all-in-one}}"

# openssh | tailscale | off
TS_SSH_MODE="openssh"
case "${TAILSCALE_SSH:-openssh}" in
    0|false|FALSE|False|no|NO|No|off|OFF|Off) TS_SSH_MODE="off" ;;
    tailscale|TAILSCALE|Tailscale) TS_SSH_MODE="tailscale" ;;
    1|true|TRUE|True|yes|YES|Yes|openssh|OPENSSH|Openssh) TS_SSH_MODE="openssh" ;;
esac

# Accept subnet routes advertised by other tailnet nodes (e.g. homelab LAN via a
# subnet router). With userspace networking there is no kernel route table; the
# SOCKS/HTTP proxy only dials those prefixes when RouteAll is enabled — pair with
# TAILSCALE_OUTBOUND_PROXY=1 so Hermes traffic goes through localhost:1055.
TS_ACCEPT_ROUTES=0
case "${TAILSCALE_ACCEPT_ROUTES:-}" in
    1|true|TRUE|True|yes|YES|Yes) TS_ACCEPT_ROUTES=1 ;;
esac

mkdir -p /run/tailscale "${TS_STATE_DIR}" "${TS_STATE_DIR}/profile"

# Do not route tailscaled's own control-plane traffic through ALL_PROXY (set by
# cont-init 04 for app services). That causes startup races and spurious errors.
unset ALL_PROXY HTTP_PROXY HTTPS_PROXY http_proxy https_proxy all_proxy

export TS_LOCAL_APP_DATA="${TS_STATE_DIR}/profile"

# PMTU black-hole workaround for restrictive client paths (office NAT, PPPoE,
# stacked VPNs). Railway has no NET_ADMIN, so iptables MSS clamp is unavailable;
# TS_DEBUG_MTU is the server-side knob tailscaled reads at startup.
case "${TAILSCALE_MTU:-1200}" in
    0|false|FALSE|off|OFF|disable|DISABLE)
        ;;
    *)
        export TS_DEBUG_MTU="${TAILSCALE_MTU:-1200}"
        echo "[tailscaled] TS_DEBUG_MTU=${TS_DEBUG_MTU} (PMTU workaround; TAILSCALE_MTU=0 to disable)" >&2
        ;;
esac

echo "[tailscaled] starting userspace tailscaled (state=${TS_STATE_DIR} ssh=${TS_SSH_MODE} accept-routes=${TS_ACCEPT_ROUTES})" >&2

tailscaled \
    --tun=userspace-networking \
    --socks5-server=localhost:1055 \
    --outbound-http-proxy-listen=localhost:1055 \
    --state="${TS_STATE_DIR}/tailscaled.state" \
    --socket="${TS_SOCKET}" &

TPID=$!

_ts_up() {
    set -- \
        --auth-key="${TAILSCALE_AUTH_KEY}" \
        --hostname="${TS_HOSTNAME}" \
        --accept-dns=false
    if [ "${TS_ACCEPT_ROUTES}" = "1" ]; then
        set -- "$@" --accept-routes
    fi
    if [ "${TS_SSH_MODE}" = "tailscale" ]; then
        set -- "$@" --ssh
    fi
    tailscale --socket="${TS_SOCKET}" up "$@"
}

while ! _ts_up; do
    sleep 0.5
done

if [ "${TS_SSH_MODE}" = "tailscale" ]; then
    tailscale --socket="${TS_SOCKET}" set --ssh 2>/dev/null || true
elif [ "${TS_SSH_MODE}" = "openssh" ]; then
    if command -v sshd >/dev/null 2>&1; then
        mkdir -p /run/sshd
        ssh-keygen -A 2>/dev/null || true
        /usr/sbin/sshd -e 2>/dev/null &
        sleep 0.5
        if tailscale --socket="${TS_SOCKET}" serve --bg --tcp 22 127.0.0.1:22 2>/dev/null; then
            echo "[tailscaled] openssh on 127.0.0.1:22 via tailscale serve (add keys to ${DATA_DIR}/.ssh/authorized_keys)" >&2
        else
            echo "[tailscaled] warning: tailscale serve for SSH failed; check tailscale serve status" >&2
        fi
    else
        echo "[tailscaled] warning: openssh-server not installed; set TAILSCALE_SSH=tailscale or rebuild image" >&2
    fi
fi

echo "[tailscaled] joined tailnet as ${TS_HOSTNAME} (ssh=${TS_SSH_MODE})" >&2
if [ "${TS_SSH_MODE}" = "tailscale" ]; then
    echo "[tailscaled] warning: Tailscale SSH often hangs on userspace (no remote SSH banner); prefer TAILSCALE_SSH=openssh" >&2
fi

wait "${TPID}"
