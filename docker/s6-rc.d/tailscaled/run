#!/command/with-contenv sh
# shellcheck shell=sh
# Tailscale userspace networking (no TUN / NET_ADMIN) for Railway and similar hosts.
# Inbound: tailnet → Tailscale IP:$PORT forwards to localhost:$PORT (control plane).
# Outbound to other tailnet nodes: optional TAILSCALE_OUTBOUND_PROXY (see cont-init 04).

# No auth key: hold the dependency slot open without joining a tailnet.
case "${TAILSCALE_AUTH_KEY:-}" in
    "") exec sleep infinity ;;
esac

DATA_DIR="${HERMES_DATA_DIR:-/opt/data}"
TS_STATE_DIR="${TAILSCALE_STATE_DIR:-${DATA_DIR}/.tailscale}"
TS_SOCKET="${TAILSCALE_SOCKET:-/run/tailscale/tailscaled.sock}"
TS_HOSTNAME="${TAILSCALE_HOSTNAME:-${RAILWAY_SERVICE_NAME:-hermes-all-in-one}}"

mkdir -p /run/tailscale "${TS_STATE_DIR}" "${TS_STATE_DIR}/profile"

# Do not route tailscaled's own control-plane traffic through ALL_PROXY (set by
# cont-init 04 for app services). That causes startup races and spurious errors.
unset ALL_PROXY HTTP_PROXY HTTPS_PROXY http_proxy https_proxy all_proxy

export TS_LOCAL_APP_DATA="${TS_STATE_DIR}/profile"

# Tailscale SSH (not openssh on :22): advertises SSH on the tailnet per ACL policy.
# Disable with TAILSCALE_SSH=0. Requires an ssh rule in the tailnet ACL — see README.
TS_SSH=0
case "${TAILSCALE_SSH:-1}" in
    1|true|TRUE|True|yes|YES|Yes) TS_SSH=1 ;;
esac

echo "[tailscaled] starting userspace tailscaled (state=${TS_STATE_DIR} ssh=${TS_SSH})" >&2

tailscaled \
    --tun=userspace-networking \
    --socks5-server=localhost:1055 \
    --outbound-http-proxy-listen=localhost:1055 \
    --state="${TS_STATE_DIR}/tailscaled.state" \
    --socket="${TS_SOCKET}" &

TPID=$!

while true; do
    if [ "${TS_SSH}" -eq 1 ]; then
        if tailscale --socket="${TS_SOCKET}" up \
            --auth-key="${TAILSCALE_AUTH_KEY}" \
            --hostname="${TS_HOSTNAME}" \
            --accept-dns=false \
            --ssh; then
            break
        fi
    else
        if tailscale --socket="${TS_SOCKET}" up \
            --auth-key="${TAILSCALE_AUTH_KEY}" \
            --hostname="${TS_HOSTNAME}" \
            --accept-dns=false; then
            break
        fi
    fi
    sleep 0.5
done

# Ensure SSH stays enabled after volume reuse (node may have joined without --ssh earlier).
if [ "${TS_SSH}" -eq 1 ]; then
    tailscale --socket="${TS_SOCKET}" set --ssh 2>/dev/null || true
fi

echo "[tailscaled] joined tailnet as ${TS_HOSTNAME} (ssh=${TS_SSH})" >&2
wait "${TPID}"
