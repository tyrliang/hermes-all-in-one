#!/command/with-contenv sh
# shellcheck shell=sh
# Public Starlette control plane — proxies to loopback WebUI and serves /admin.

export HOME="${HOME:-${HERMES_DATA_DIR:-/opt/data}}"
export HERMES_DATA_DIR="${HERMES_DATA_DIR:-/opt/data}"
export HERMES_HOME="${HERMES_HOME:-${HERMES_DATA_DIR}/.hermes}"
cd "$HOME"

# shellcheck disable=SC1091
. /opt/hermes/.venv/bin/activate

export PYTHONPATH="/app:${PYTHONPATH:-}"
export HERMES_WEBUI_AGENT_DIR="${HERMES_WEBUI_AGENT_DIR:-/opt/hermes}"
export HERMES_WEBUI_STATE_DIR="${HERMES_WEBUI_STATE_DIR:-${HERMES_DATA_DIR}/webui}"
export HERMES_WORKSPACE_DIR="${HERMES_WORKSPACE_DIR:-${HERMES_DATA_DIR}/workspace}"
export HERMES_CONFIG_PATH="${HERMES_CONFIG_PATH:-${HERMES_HOME}/config.yaml}"
export CONTROL_PLANE_HOST="${CONTROL_PLANE_HOST:-0.0.0.0}"
export CONTROL_PLANE_RUNTIME=s6

# shellcheck source=/app/docker/scripts/import-docker-env.sh
. /app/docker/scripts/import-docker-env.sh
import_docker_env HERMES_WEBUI_PASSWORD HERMES_ADMIN_PASSWORD PORT

export HERMES_WEBUI_PASSWORD="${HERMES_WEBUI_PASSWORD:-}"
export HERMES_ADMIN_PASSWORD="${HERMES_ADMIN_PASSWORD:-${HERMES_WEBUI_PASSWORD:-}}"

exec s6-setuidgid hermes python -m uvicorn control_plane.server:app \
    --host "${CONTROL_PLANE_HOST}" \
    --port "${PORT:-8787}"
