# Local dev only. On Railway, do NOT set PORT — the platform injects it (usually 8080).
# PORT=8787

# Shared Hermes runtime (official image layout — mount Railway volume at /opt/data)
HERMES_HOME=/opt/data
HERMES_DATA_DIR=/opt/data
HERMES_CONFIG_PATH=/opt/data/config.yaml
HERMES_WORKSPACE_DIR=/opt/data/workspace

# Internal WebUI runtime (public traffic is still served from / via the control plane)
HERMES_WEBUI_STATE_DIR=/opt/data/webui
HERMES_WEBUI_AGENT_DIR=/opt/hermes
CONTROL_PLANE_RUNTIME=s6
# Internal WebUI (loopback only — proxied by the control plane; do not expose publicly)
CONTROL_PLANE_INTERNAL_WEBUI_HOST=127.0.0.1
CONTROL_PLANE_INTERNAL_WEBUI_PORT=8788

# Public control plane bind address (Railway traffic hits this on $PORT)
CONTROL_PLANE_HOST=0.0.0.0
HERMES_ADMIN_USERNAME=admin
# Recommended: set a dedicated admin password. If omitted, the wrapper falls back to HERMES_WEBUI_PASSWORD.
HERMES_ADMIN_PASSWORD=***

# WebUI auth
HERMES_WEBUI_PASSWORD=***

# Gateway autostart policy:
# - auto: start only when a valid provider + at least one channel are configured
# - 1/true/on: force autostart when config is sufficient
# - 0/false/off: never autostart
HERMES_GATEWAY_AUTOSTART=auto

# Common channel env vars you may set through /admin or directly in Railway
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# EMAIL_ADDRESS=

# API-key happy-path providers
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Advanced/manual flows such as OpenAI Codex / ChatGPT-style login remain terminal-first.

# --- Agent Vault (optional — remote broker) ---
# When set, the container entrypoint runs `agent-vault run` before s6 /init.
# Real API keys live in the Agent Vault UI only; use placeholders on the volume:
#   templates/hermes-data.env.example → /opt/data/.env
#
# 1. Deploy Agent Vault broker (see https://docs.agent-vault.dev/guides/hermes-on-vps)
# 2. Set Railway (or compose) vars below — ensure network access to :14321 / :14322
# 3. Copy placeholder keys to /opt/data/.env (never put real secrets there with vault on)
# 4. Configure providers/channels in /admin without pasting real keys into the volume
# 5. Verify gateway logs under /opt/data/logs/
#
# AGENT_VAULT_ADDR=https://vault.example.com:14321
# AGENT_VAULT_TOKEN=av_agt_...
# AGENT_VAULT_VAULT=prod
# AGENT_VAULT_SKILLS_REF=main
#
# TLS / proxy (usually set by `agent-vault run` on PID 1; uncomment for compose exec debugging)
# SSL_CERT_FILE=/opt/data/.agent-vault-mitm-ca.pem
# REQUESTS_CA_BUNDLE=/opt/data/.agent-vault-mitm-ca.pem
# NO_PROXY=localhost,127.0.0.1,<broker-hostname>
#
# Docs: https://docs.agent-vault.dev/guides/deploy-agent-container
#       https://docs.agent-vault.dev/quickstart/hermes-agent
