# Copy to /opt/data/.env on your Railway volume when using Agent Vault.
# Real secrets live in the vault UI; placeholders must match substitution rules
# configured in Agent Vault (see README — Agent Vault section).
#
# https://docs.agent-vault.dev/guides/hermes-on-vps

# --- LLM (example: Anthropic direct) ---
ANTHROPIC_API_KEY=__anthropic_api_key__

# --- OpenCode Go (Agent Vault service host: opencode.ai/zen/go/*) ---
# OPENCODE_GO_API_KEY=__opencode_go_api_key__

# --- GitHub (Agent Vault service host: *.github.com or api.github.com) ---
# GITHUB_TOKEN=__github_key__

# --- Common integrations (uncomment what you configured in Agent Vault) ---
# OPENROUTER_API_KEY=__openrouter_api_key__
# OPENAI_API_KEY=__openai_api_key__
# SLACK_BOT_TOKEN=__slack_bot_token__
# SLACK_APP_TOKEN=__slack_app_token__
# TELEGRAM_BOT_TOKEN=__telegram_bot_token__
# DISCORD_BOT_TOKEN=__discord_bot_token__
# EMAIL_ADDRESS=__email_address__

# Mission Control hook (not brokered — keep real values if used)
# MC_URL=http://mission-control:3000
# MC_API_KEY=
